{
  "name": "linux-share-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun --hot src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "bun run build:web && bun run build:server",
    "build:web": "vite build",
    "build:server": "bun build src/server/index.ts --target bun --outdir dist/server",
    "start": "bun run dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.8",
    "ky": "^2.0.2",
    "lucide-react": "^0.561.0",
    "pino": "^10.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.7",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "playwright": "^1.61.1",
    "react-doctor": "^0.7.1",
    "react-grab": "^0.1.37",
    "react-scan": "^0.5.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
